{
  "$schema": "https://developer.microsoft.com/json-schemas/powerbi/themes/reportThemeSchema-2.131.json",
  "name": "Wallboard Dark - Workout Analytics",
  "dataColors": [
    "#00E5C7",
    "#FF6B6B",
    "#FFD166",
    "#6C7BFF",
    "#C77DFF",
    "#4ADE80",
    "#38BDF8",
    "#FB923C",
    "#FF8FAB",
    "#94A3B8"
  ],
  "background": "#0B0E14",
  "foreground": "#E6E9F0",
  "tableAccent": "#00E5C7",
  "good": "#4ADE80",
  "bad": "#FF6B6B",
  "neutral": "#FFD166",
  "maximum": "#00E5C7",
  "center": "#38BDF8",
  "minimum": "#1E2433",
  "null": "#475569",

  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#E6E9F0"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 13,
      "color": "#9FB0C3"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#C7CEDB"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 32,
      "color": "#00E5C7"
    }
  },

  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "background": { "color": { "solid": { "color": "#131722" } }, "transparency": 0 },
            "border": { "show": true, "color": { "solid": { "color": "#222838" } }, "radius": 8 },
            "dropShadow": {
              "show": true,
              "color": { "solid": { "color": "#000000" } },
              "preset": "Bottom Right",
              "shadowBlur": 12,
              "shadowOpacity": 35
            },
            "general": { "responsive": true },
            "visualHeader": {
              "show": true,
              "background": { "color": { "solid": { "color": "#131722" } } },
              "foreground": { "color": { "solid": { "color": "#9FB0C3" } } },
              "border": false
            },
            "title": {
              "show": true,
              "fontColor": { "solid": { "color": "#E6E9F0" } },
              "fontSize": 13,
              "fontFamily": "Segoe UI Semibold",
              "alignment": "left",
              "background": { "solid": { "color": "#00000000" } }
            },
            "subTitle": {
              "show": false
            },
            "divider": {
              "show": true,
              "color": { "solid": { "color": "#222838" } },
              "linkStyle": "solid"
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#0B0E14" } }, "transparency": 0 }],
        "outspace": [{ "color": { "solid": { "color": "#05070B" } } }]
      }
    },
    "textbox": {
      "*": {
        "background": [{ "show": false }]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": "#00E5C7",
            "fontSize": 36,
            "fontFamily": "Segoe UI Semibold",
            "labelDisplayUnits": "Auto"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": "#9FB0C3",
            "fontSize": 12,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "card": [{ "outlineColor": "#222838", "outlineWeight": 1, "backgroundColor": "#131722" }]
      }
    },
    "kpi": {
      "*": {
        "trendline": [{ "color": "#00E5C7" }],
        "goalLabels": [{ "color": "#9FB0C3" }]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [{ "fill": "#00E5C7" }],
        "categoryAxis": [
          {
            "show": true,
            "color": "#9FB0C3",
            "gridlineColor": "#1B2030",
            "gridlineShow": false,
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "color": "#9FB0C3",
            "gridlineColor": "#1B2030",
            "gridlineShow": true,
            "fontSize": 10
          }
        ],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }],
        "lineStyles": [{ "lineThickness": 3, "shadow": true }]
      }
    },
    "columnChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false, "fontSize": 10 }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": "#1B2030", "gridlineShow": true, "fontSize": 10 }],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }],
        "dataPoint": [{ "fill": "#00E5C7" }]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false, "fontSize": 10 }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": "#1B2030", "gridlineShow": true, "fontSize": 10 }],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }]
      }
    },
    "areaChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": "#1B2030", "gridlineShow": true }],
        "fillPoint": [{ "show": true }]
      }
    },
    "scatterChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": "#1B2030", "gridlineShow": true }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": "#1B2030", "gridlineShow": true }],
        "fillPoint": [{ "show": true }],
        "bubbles": [{ "bubbleSize": 0 }]
      }
    },
    "pieChart": {
      "*": {
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Right" }],
        "labels": [{ "color": "#0B0E14", "fontSize": 10, "show": true }]
      }
    },
    "donutChart": {
      "*": {
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Right" }],
        "labels": [{ "color": "#E6E9F0", "fontSize": 10, "show": true }]
      }
    },
    "treemap": {
      "*": {
        "labels": [{ "color": "#0B0E14", "fontSize": 10 }],
        "legend": [{ "show": false }],
        "categoryLabels": [{ "show": true, "color": "#0B0E14" }]
      }
    },
    "gauge": {
      "*": {
        "dataPoint": [{ "fillColor": "#00E5C7", "targetColor": "#FF6B6B" }],
        "calloutValue": [{ "color": "#E6E9F0", "fontSize": 22 }]
      }
    },
    "tableEx": {
      "*": {
        "grid": [{ "gridVertical": false, "gridHorizontalColor": "#1B2030", "rowPadding": 6 }],
        "columnHeaders": [
          {
            "fontColor": "#9FB0C3",
            "backColor": "#131722",
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": "#E6E9F0",
            "backColor": "#0F131C",
            "fontSize": 11,
            "backColorPrimary": "#0F131C",
            "backColorSecondary": "#131722"
          }
        ],
        "total": [{ "fontColor": "#00E5C7", "backColor": "#131722" }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{ "fontColor": "#9FB0C3", "backColor": "#131722" }],
        "values": [{ "fontColor": "#E6E9F0", "backColor": "#0F131C" }],
        "rowHeaders": [{ "fontColor": "#C7CEDB", "backColor": "#131722" }]
      }
    },
    "slicer": {
      "*": {
        "general": [{ "outlineColor": "#222838", "outlineWeight": 1 }],
        "header": [
          {
            "show": true,
            "fontColor": "#9FB0C3",
            "background": "#131722",
            "fontSize": 11
          }
        ],
        "items": [
          {
            "fontColor": "#E6E9F0",
            "background": "#0F131C",
            "selectedColor": "#00E5C7",
            "hoverColor": "#1B2030",
            "fontSize": 11
          }
        ],
        "date": [{ "fontColor": "#E6E9F0", "background": "#0F131C" }]
      }
    },
    "shape": {
      "*": {
        "fill": [{ "fillColor": "#131722" }],
        "outline": [{ "lineColor": "#222838" }]
      }
    }
  }
}
