{
  "$schema": "https://developer.microsoft.com/json-schemas/powerbi/themes/reportThemeSchema-2.131.json",
  "name": "Wallboard Dark - Workout Analytics",
  "dataColors": [
    "#00E5C7",
    "#FF6B6B",
    "#FFD166",
    "#6C7BFF",
    "#C77DFF",
    "#4ADE80",
    "#38BDF8",
    "#FB923C",
    "#FF8FAB",
    "#94A3B8"
  ],
  "background": "#0B0E14",
  "foreground": "#E6E9F0",
  "tableAccent": "#00E5C7",
  "good": "#4ADE80",
  "bad": "#FF6B6B",
  "neutral": "#FFD166",
  "maximum": "#00E5C7",
  "center": "#38BDF8",
  "minimum": "#1E2433",
  "null": "#475569",

  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 16,
      "color": "#E6E9F0"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 13,
      "color": "#9FB0C3"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 11,
      "color": "#C7CEDB"
    },
    "callout": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 32,
      "color": "#00E5C7"
    }
  },

  "visualStyles": {
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#0B0E14" } }, "transparency": 0 }],
        "outspace": [{ "color": { "solid": { "color": "#05070B" } } }]
      }
    },
    "textbox": {
      "*": {
        "background": [{ "show": false }]
      }
    },
    "shape": {
      "*": {
        "fill": [{ "fillColor": { "solid": { "color": "#131722" } } }],
        "outline": [{ "lineColor": { "solid": { "color": "#222838" } } }]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#00E5C7" } },
            "fontSize": 36,
            "fontFamily": "Segoe UI Semibold",
            "labelDisplayUnits": "0"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#9FB0C3" } },
            "fontSize": 12,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "card": [{ "outlineColor": { "solid": { "color": "#222838" } }, "outlineWeight": 1, "backgroundColor": "#131722" }]
      }
    },
    "lineChart": {
      "*": {
        "dataPoint": [{ "fill": { "solid": { "color": "#00E5C7" } } }],
        "categoryAxis": [
          {
            "show": true,
            "color": "#9FB0C3",
            "gridlineColor": { "solid": { "color": "#1B2030" } },
            "gridlineShow": false,
            "fontSize": 10
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "color": "#9FB0C3",
            "gridlineColor": { "solid": { "color": "#1B2030" } },
            "gridlineShow": true,
            "fontSize": 10
          }
        ],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }],
        "lineStyles": [{ "lineThickness": 3, "shadow": true }]
      }
    },
    "columnChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false, "fontSize": 10 }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": { "solid": { "color": "#1B2030" } }, "gridlineShow": true, "fontSize": 10 }],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }],
        "dataPoint": [{ "fill": { "solid": { "color": "#00E5C7" } } }]
      }
    },
    "barChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false, "fontSize": 10 }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": { "solid": { "color": "#1B2030" } }, "gridlineShow": true, "fontSize": 10 }],
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Top" }]
      }
    },
    "areaChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineShow": false }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": { "solid": { "color": "#1B2030" } }, "gridlineShow": true }],
        "fillPoint": [{ "show": true }]
      }
    },
    "scatterChart": {
      "*": {
        "categoryAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": { "solid": { "color": "#1B2030" } }, "gridlineShow": true }],
        "valueAxis": [{ "show": true, "color": "#9FB0C3", "gridlineColor": { "solid": { "color": "#1B2030" } }, "gridlineShow": true }],
        "fillPoint": [{ "show": true }]
      }
    },
    "pieChart": {
      "*": {
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Right" }],
        "labels": [{ "color": { "solid": { "color": "#0B0E14" } }, "fontSize": 10, "show": true }]
      }
    },
    "donutChart": {
      "*": {
        "legend": [{ "show": true, "color": "#C7CEDB", "fontSize": 10, "position": "Right" }],
        "labels": [{ "color": { "solid": { "color": "#E6E9F0" } }, "fontSize": 10, "show": true }]
      }
    },
    "treemap": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#0B0E14" } }, "fontSize": 10 }],
        "legend": [{ "show": false }],
        "categoryLabels": [{ "show": true, "color": { "solid": { "color": "#0B0E14" } } }]
      }
    },
    "gauge": {
      "*": {
        "dataPoint": [{ "fillColor": "#00E5C7", "targetColor": "#FF6B6B" }],
        "calloutValue": [{ "color": { "solid": { "color": "#E6E9F0" } }, "fontSize": 22 }]
      }
    },
    "tableEx": {
      "*": {
        "grid": [{ "gridVertical": false, "gridHorizontalColor": { "solid": { "color": "#1B2030" } }, "rowPadding": 6 }],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#9FB0C3" } },
            "backColor": { "solid": { "color": "#131722" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#E6E9F0" } },
            "backColor": { "solid": { "color": "#0F131C" } },
            "fontSize": 11,
            "backColorPrimary": { "solid": { "color": "#0F131C" } },
            "backColorSecondary": { "solid": { "color": "#131722" } }
          }
        ],
        "total": [{ "fontColor": { "solid": { "color": "#00E5C7" } }, "backColor": { "solid": { "color": "#131722" } } }]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [{ "fontColor": { "solid": { "color": "#9FB0C3" } }, "backColor": { "solid": { "color": "#131722" } } }],
        "values": [{ "fontColor": { "solid": { "color": "#E6E9F0" } }, "backColor": { "solid": { "color": "#0F131C" } } }],
        "rowHeaders": [{ "fontColor": { "solid": { "color": "#C7CEDB" } }, "backColor": { "solid": { "color": "#131722" } } }]
      }
    },
    "slicer": {
      "*": {
        "general": [{ "outlineColor": { "solid": { "color": "#222838" } }, "outlineWeight": 1 }],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#9FB0C3" } },
            "background": { "solid": { "color": "#131722" } },
            "fontSize": 11
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#E6E9F0" } },
            "background": { "solid": { "color": "#0F131C" } },
            "selectedColor": "#00E5C7",
            "hoverColor": "#1B2030",
            "fontSize": 11
          }
        ],
        "date": [{ "fontColor": { "solid": { "color": "#E6E9F0" } }, "background": { "solid": { "color": "#0F131C" } } }]
      }
    }
  }
}
