	column 'day_of_week (groups)' =
			SWITCH(
				TRUE,
				ISBLANK('calendar'[day_of_week]),
				"(Blank)",
				'calendar'[day_of_week] IN {"5"},
				"Friday",
				'calendar'[day_of_week] IN {"1"},
				"Monday",
				'calendar'[day_of_week] IN {"6"},
				"Saturday",
				'calendar'[day_of_week] IN {"7"},
				"Sunday",
				'calendar'[day_of_week] IN {"4"},
				"Thursday",
				'calendar'[day_of_week] IN {"2"},
				"Tuesday",
				'calendar'[day_of_week] IN {"3"},
				"Wednesday",
				'calendar'[day_of_week]
			)
		lineageTag: 657be4e2-ff13-4fd5-94a8-939280c87156
		summarizeBy: none

		extendedProperty GroupingMetadata =
